rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email']) 
        && data.email is string && data.email.size() <= 200
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100));
    }
    
    function isValidSubject(data, parentId) {
      return data.keys().hasAll(['userId', 'name', 'type', 'url'])
        && data.userId == parentId
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.type is string && (data.type == 'character' || data.type == 'object')
        && data.url is string && data.url.size() <= 2000
        && (!('objectCategory' in data) || (data.objectCategory is string && data.objectCategory.size() <= 100));
    }

    function isValidDestination(data, parentId) {
      return data.keys().hasAll(['userId', 'destination', 'imageUrl', 'createdAt'])
        && data.userId == parentId
        && data.userId == request.auth.uid
        && data.destination is string && data.destination.size() <= 200
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.createdAt is number
        && (!('description' in data) || (data.description is string && data.description.size() <= 1000))
        && (!('isFavorite' in data) || data.isFavorite is bool);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      match /data/appData {
      	allow get: if isOwner(userId) && isValidId(userId);
        allow update, create: if isOwner(userId) && isValidId(userId);
      }
      
      match /subjects/{subjectId} {
        allow read: if isOwner(userId) && isValidId(userId) && isValidId(subjectId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(subjectId) && isValidSubject(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(subjectId) && isValidSubject(incoming(), userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(subjectId);
      }
      
      match /destinations/{destinationId} {
        allow read: if isOwner(userId) && isValidId(userId) && isValidId(destinationId);
        allow list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(destinationId) && isValidDestination(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(destinationId) && isValidDestination(incoming(), userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(destinationId);
      }
    }
  }
}
