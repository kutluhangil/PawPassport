# ============================================
# MinikGezgin — Environment Variables
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
# cp .env.example .env

# --------------------------------------------
# Gemini AI (ZORUNLU — Görsel oluşturma için)
# --------------------------------------------
# Google AI Studio'dan alın: https://aistudio.google.com/app/apikey
# NOT: Görsel oluşturma (Gemini 3.1 Flash Image) için ÜCRETLI proje gereklidir!
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --------------------------------------------
# Firebase (ZORUNLU — Auth ve Firestore için)
# --------------------------------------------
# Firebase Console'dan alın: https://console.firebase.google.com
# Proje: subscriptionhub-85b02
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY_HERE"
VITE_FIREBASE_AUTH_DOMAIN="subscriptionhub-85b02.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="subscriptionhub-85b02"
VITE_FIREBASE_STORAGE_BUCKET="subscriptionhub-85b02.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="86302718224"
VITE_FIREBASE_APP_ID="1:86302718224:web:fdc9408d0e2fdee2050d95"

# --------------------------------------------
# Uygulama (İsteğe bağlı)
# --------------------------------------------
APP_URL="http://localhost:5173"
